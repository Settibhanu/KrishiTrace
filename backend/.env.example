# ============================================================
# Krishi-Trace AI — Backend Environment Variables
# ============================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For Vercel deployment, set these in the Vercel project
# dashboard under Settings → Environment Variables.
# ============================================================

# TCP port the Express server listens on (Vercel ignores this).
PORT=5000

# MongoDB connection string.
# Use MongoDB Atlas for production: mongodb+srv://user:pass@cluster.mongodb.net/krishi_trace
MONGO_URI=mongodb://localhost:27017/krishi_trace

# Secret key used to sign and verify JSON Web Tokens.
# Use a long random string in production (e.g. openssl rand -hex 32).
JWT_SECRET=your_jwt_secret_here

# ── Blockchain (optional — simulated by default) ──────────────
# Uncomment and fill in when connecting to a real Ethereum node.
# BLOCKCHAIN_RPC_URL=http://localhost:8545
# CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
# PRIVATE_KEY=your_private_key_here

# ── CORS (production only) ────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Leave unset in development to allow all origins.
# Example: https://krishi-trace.vercel.app,https://www.krishi-trace.com
# FRONTEND_URL=https://your-frontend.vercel.app

# ── Vercel serverless flag ────────────────────────────────────
# Vercel automatically sets this to "1" — do NOT set it manually.
# It prevents app.listen() from being called inside a serverless function.
# VERCEL=1
