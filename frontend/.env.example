# ============================================================
# Krishi-Trace AI — Frontend Environment Variables
# ============================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For Vercel deployment, set these in the Vercel project
# dashboard under Settings → Environment Variables.
# ============================================================

# URL of the deployed backend API.
# - Local development: http://localhost:5000/api
# - Vercel production:  https://your-backend-project.vercel.app/api
VITE_API_URL=http://localhost:5000/api
